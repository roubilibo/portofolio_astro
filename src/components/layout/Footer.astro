---
import { Github, Linkedin, Mail } from "lucide-astro";
import { siteConfig } from "@/config/site";

const year = new Date().getFullYear();
---

<footer class="border-t border-[var(--border)] bg-[var(--surface)]">
  <div class="container-page flex flex-col gap-6 py-8 md:flex-row md:items-center md:justify-between">
    <div>
      <p class="font-bold">{siteConfig.name}</p>
      <p class="mt-1 text-sm text-muted">© {year}. Dibangun dengan Astro, TypeScript, dan Tailwind CSS.</p>
    </div>
    <div class="flex items-center gap-2">
      <a class="inline-flex size-10 items-center justify-center rounded-md border border-[var(--border)] hover:border-[var(--accent)]" href={`mailto:${siteConfig.email}`} aria-label="Email">
        <Mail class="size-4" aria-hidden="true" />
      </a>
      <a class="inline-flex size-10 items-center justify-center rounded-md border border-[var(--border)] hover:border-[var(--accent)]" href={siteConfig.github} aria-label="GitHub">
        <Github class="size-4" aria-hidden="true" />
      </a>
      <a class="inline-flex size-10 items-center justify-center rounded-md border border-[var(--border)] hover:border-[var(--accent)]" href={siteConfig.linkedin} aria-label="LinkedIn">
        <Linkedin class="size-4" aria-hidden="true" />
      </a>
    </div>
  </div>
</footer>
