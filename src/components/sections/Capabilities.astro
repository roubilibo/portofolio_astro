---
import { Cloud, Code2, Database, Server } from "lucide-astro";

const capabilities = [
  {
    title: "Frontend Development",
    description: "Membangun antarmuka React dan Next.js yang responsif, terstruktur, dan nyaman digunakan untuk pekerjaan administratif.",
    icon: Code2,
  },
  {
    title: "Backend Development",
    description: "Membuat REST API, autentikasi, role, dan proses bisnis menggunakan Node.js, Express, Fastify, Laravel, atau CodeIgniter.",
    icon: Server,
  },
  {
    title: "Database Engineering",
    description: "Mengelola skema, relasi tabel, query SQL, rekap data, dan analisis bottleneck pada database relasional.",
    icon: Database,
  },
  {
    title: "Deployment & Infrastructure",
    description: "Menyiapkan deployment dengan Docker, Nginx, Linux, VPS, Google Cloud Platform, dan konfigurasi reverse proxy.",
    icon: Cloud,
  },
];
---

<section class="section-padding bg-[var(--surface)]">
  <div class="container-page">
    <div class="max-w-2xl">
      <p class="badge">Kemampuan utama</p>
      <h2 class="mt-4 text-3xl font-black tracking-[0] md:text-4xl">Fokus pada sistem web yang nyata digunakan</h2>
      <p class="mt-4 leading-7 text-muted">Saya lebih menonjolkan cara menyelesaikan masalah teknis daripada sekadar daftar stack.</p>
    </div>
    <div class="mt-10 grid gap-4 md:grid-cols-2 lg:grid-cols-4">
      {capabilities.map((item) => (
        <article class="surface-card rounded-lg p-5">
          <item.icon class="size-6 text-[var(--accent)]" aria-hidden="true" />
          <h3 class="mt-4 text-lg font-bold">{item.title}</h3>
          <p class="mt-3 text-sm leading-6 text-muted">{item.description}</p>
        </article>
      ))}
    </div>
  </div>
</section>
