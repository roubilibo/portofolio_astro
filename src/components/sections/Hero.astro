---
import { ArrowRight, Github, Linkedin, Mail } from "lucide-astro";
import ButtonLink from "@/components/ui/ButtonLink.astro";
import { siteConfig } from "@/config/site";

const codeSnippet = `const focus = [
  "frontend",
  "backend",
  "database",
  "deployment",
  "debugging"
];

buildSystem({
  stack: "TypeScript",
  delivery: "Docker + Nginx",
  goal: "maintainable apps"
});`;
---

<section class="container-page grid gap-10 pt-12 pb-14 md:grid-cols-[1.05fr_0.95fr] md:items-center md:pt-16 lg:gap-16">
  <div class="animate-in">
    <p class="badge">Tersedia untuk kolaborasi profesional</p>
    <h1 class="mt-6 text-4xl font-black leading-tight tracking-[0] text-[var(--text)] sm:text-5xl lg:text-6xl">
      {siteConfig.name}
    </h1>
    <p class="mt-4 text-xl font-bold text-[var(--accent-strong)]">{siteConfig.position}</p>
    <p class="mt-5 max-w-2xl text-base leading-8 text-muted sm:text-lg">
      Saya membangun aplikasi administrasi, sistem informasi, REST API, integrasi database, dan deployment yang stabil. Fokus saya adalah membuat sistem yang jelas alurnya, mudah dirawat, dan dapat ditelusuri saat terjadi masalah.
    </p>
    <div class="mt-8 flex flex-wrap gap-3">
      <ButtonLink href="/projects/">
        Lihat Proyek
        <ArrowRight class="size-4" aria-hidden="true" />
      </ButtonLink>
      <ButtonLink href="/contact/" variant="secondary">
        <Mail class="size-4" aria-hidden="true" />
        Hubungi Saya
      </ButtonLink>
    </div>
    <div class="mt-6 flex gap-2">
      <a class="inline-flex size-11 items-center justify-center rounded-md border border-[var(--border)] bg-[var(--surface)] hover:border-[var(--accent)]" href={siteConfig.github} aria-label="GitHub M. Roubil Ridlo">
        <Github class="size-5" aria-hidden="true" />
      </a>
      <a class="inline-flex size-11 items-center justify-center rounded-md border border-[var(--border)] bg-[var(--surface)] hover:border-[var(--accent)]" href={siteConfig.linkedin} aria-label="LinkedIn M. Roubil Ridlo">
        <Linkedin class="size-5" aria-hidden="true" />
      </a>
    </div>
  </div>

  <div class="surface-card animate-in rounded-lg p-4 md:p-5" style="animation-delay:120ms">
    <div class="rounded-md border border-[var(--border)] bg-[#07111f] p-4 text-slate-100 shadow-inner">
      <div class="flex items-center gap-2 border-b border-slate-700 pb-3">
        <span class="size-3 rounded-full bg-red-400"></span>
        <span class="size-3 rounded-full bg-amber-300"></span>
        <span class="size-3 rounded-full bg-emerald-400"></span>
        <span class="ml-2 text-xs text-slate-400">portfolio/system-flow.ts</span>
      </div>
      <pre class="mt-5 overflow-x-auto text-sm leading-7"><code>{codeSnippet}</code></pre>
    </div>
    <div class="mt-4 grid grid-cols-2 gap-3 text-sm">
      <div class="rounded-md border border-[var(--border)] bg-[var(--surface-muted)] p-4">
        <p class="font-bold">REST API</p>
        <p class="mt-1 text-muted">Autentikasi, role, query, dan integrasi data.</p>
      </div>
      <div class="rounded-md border border-[var(--border)] bg-[var(--surface-muted)] p-4">
        <p class="font-bold">Deployment</p>
        <p class="mt-1 text-muted">Docker, Nginx, VPS, dan GCP.</p>
      </div>
    </div>
  </div>
</section>
