---
import { technologyGroups } from "@/data/technologies";
---

<section class="section-padding bg-[var(--surface)]">
  <div class="container-page">
    <div class="max-w-2xl">
      <p class="badge">Teknologi</p>
      <h2 class="mt-4 text-3xl font-black tracking-[0] md:text-4xl">Stack yang biasa digunakan</h2>
      <p class="mt-4 leading-7 text-muted">Dikelompokkan berdasarkan area kerja, tanpa progress bar atau persentase yang sulit diverifikasi.</p>
    </div>
    <div class="mt-10 grid gap-4 md:grid-cols-2">
      {technologyGroups.map((group) => (
        <article class="surface-card rounded-lg p-5">
          <h3 class="text-lg font-bold">{group.title}</h3>
          <div class="mt-5 flex flex-wrap gap-2">
            {group.items.map((item) => <span class="badge">{item}</span>)}
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
