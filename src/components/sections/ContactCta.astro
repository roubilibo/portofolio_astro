---
import { Github, Linkedin, Mail, MessageCircle } from "lucide-astro";
import { siteConfig } from "@/config/site";
---

<section class="section-padding bg-[var(--surface)]">
  <div class="container-page">
    <div class="surface-card rounded-lg p-6 md:p-8">
      <div class="grid gap-8 md:grid-cols-[1fr_1.1fr] md:items-center">
        <div>
          <p class="badge">Kontak</p>
          <h2 class="mt-4 text-3xl font-black tracking-[0] md:text-4xl">
            Diskusikan kebutuhan aplikasi atau perbaikan sistem
          </h2>
          <p class="mt-4 leading-7 text-muted">{siteConfig.availability}</p>
        </div>
        <div class="grid gap-3 sm:grid-cols-2">
          <a
            class="rounded-md border border-[var(--border)] p-4 hover:border-[var(--accent)]"
            href={`mailto:${siteConfig.email}`}
          >
            <Mail class="size-5 text-[var(--accent)]" aria-hidden="true" />
            <p class="mt-3 font-bold">Email</p>
            <p class="mt-1 break-words text-sm text-muted">
              {siteConfig.email}
            </p>
          </a>
          <a
            class="rounded-md border border-[var(--border)] p-4 hover:border-[var(--accent)]"
            href={siteConfig.whatsapp}
          >
            <MessageCircle
              class="size-5 text-[var(--accent)]"
              aria-hidden="true"
            />
            <p class="mt-3 font-bold">WhatsApp</p>
            <p class="mt-1 text-sm text-muted">0852-3111-3485</p>
          </a>
          <a
            class="rounded-md border border-[var(--border)] p-4 hover:border-[var(--accent)]"
            href={siteConfig.github}
          >
            <Github class="size-5 text-[var(--accent)]" aria-hidden="true" />
            <p class="mt-3 font-bold">GitHub</p>
            <p class="mt-1 text-sm text-muted">Lihat repository</p>
          </a>
          <a
            class="rounded-md border border-[var(--border)] p-4 hover:border-[var(--accent)]"
            href={siteConfig.linkedin}
          >
            <Linkedin class="size-5 text-[var(--accent)]" aria-hidden="true" />
            <p class="mt-3 font-bold">LinkedIn</p>
            <p class="mt-1 text-sm text-muted">Profil profesional</p>
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
